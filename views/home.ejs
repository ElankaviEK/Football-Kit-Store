<%- include('partials/header') %>

<section class="hero-section">
  <div class="container text-center">
    <h1 class="hero-title">The World's Best<br><span class="text-accent">Football Kits</span></h1>
    <p class="hero-sub">Official jerseys, training kits & more. Club and national teams.</p>
    <a href="/products" class="btn btn-accent btn-lg me-2">Shop Now</a>
    <a href="/products?category=Jersey" class="btn btn-outline-light btn-lg">View Jerseys</a>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <h2 class="section-title">Shop by Category</h2>
    <div class="row g-3 mb-5">
      <% const catIcons = { Jersey: 'bi-award', National: 'bi-flag', Kit: 'bi-bag', Shorts: 'bi-shorts', Goalkeeper: 'bi-shield' }; %>
      <% categories.forEach(c => { %>
      <div class="col-6 col-md-3 col-lg-2">
        <a href="/products?category=<%= encodeURIComponent(c.category) %>" class="category-card text-decoration-none">
          <i class="bi <%= catIcons[c.category] || 'bi-grid' %>"></i>
          <span><%= c.category %></span>
        </a>
      </div>
      <% }) %>
    </div>

    <h2 class="section-title">Featured Products</h2>
    <div class="row g-4">
      <% featured.forEach(p => { %>
      <div class="col-6 col-md-4 col-lg-3">
        <div class="product-card h-100">
          <a href="/products/<%= p.id %>" class="text-decoration-none">
            <div class="product-img-wrap">
              <img src="https://via.placeholder.com/300x300/1a1a2e/ffffff?text=<%= encodeURIComponent(p.name.split(' ').slice(0,2).join('+')) %>"
                   alt="<%= p.name %>" class="product-img">
              <% if (p.stock < 5 && p.stock > 0) { %><span class="badge-low-stock">Low Stock</span><% } %>
              <% if (p.stock === 0) { %><span class="badge-out-stock">Out of Stock</span><% } %>
            </div>
            <div class="product-info">
              <p class="product-category"><%= p.category %></p>
              <h6 class="product-name"><%= p.name %></h6>
              <p class="product-price">€<%= p.price.toFixed(2) %></p>
            </div>
          </a>
          <% if (p.stock > 0) { %>
          <form action="/cart/add" method="POST" class="px-3 pb-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="productId" value="<%= p.id %>">
            <input type="hidden" name="qty" value="1">
            <button type="submit" class="btn btn-accent w-100 btn-sm">Add to Cart</button>
          </form>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
