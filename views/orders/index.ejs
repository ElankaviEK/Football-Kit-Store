<%- include('../partials/header') %>

<div class="container py-5">
  <h1 class="page-title mb-4"><i class="bi bi-box"></i> My Orders</h1>

  <% if (typeof query !== 'undefined' && query.success) { %>
    <div class="alert alert-success"><i class="bi bi-check-circle"></i> <%= query.success %></div>
  <% } %>

  <% if (orders.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-box display-2 text-muted"></i>
      <p class="mt-3 text-muted fs-5">You haven't placed any orders yet.</p>
      <a href="/products" class="btn btn-accent mt-2">Start Shopping</a>
    </div>
  <% } else { %>
    <% orders.forEach(order => { %>
    <div class="order-card mb-4">
      <div class="order-card-header d-flex justify-content-between align-items-center">
        <div>
          <span class="fw-bold">Order #<%= order.id %></span>
          <span class="text-muted small ms-3"><%= new Date(order.created_at).toLocaleDateString('en-IE', {day:'numeric',month:'short',year:'numeric'}) %></span>
        </div>
        <div>
          <span class="badge status-badge status-<%= order.status %>"><%= order.status.toUpperCase() %></span>
          <span class="fw-bold ms-3 text-accent">€<%= order.total.toFixed(2) %></span>
        </div>
      </div>
      <div class="order-card-body">
        <% order.items.forEach(item => { %>
        <div class="d-flex align-items-center gap-3 mb-2">
          <img src="https://via.placeholder.com/50x50/1a1a2e/ffffff?text=<%= encodeURIComponent(item.name.split(' ')[0]) %>"
               alt="<%= item.name %>" class="rounded" style="width:50px;height:50px;object-fit:cover;">
          <div>
            <p class="mb-0 fw-medium"><%= item.name %></p>
            <p class="mb-0 text-muted small">Qty: <%= item.quantity %> &times; €<%= item.price.toFixed(2) %></p>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>
  <% } %>
</div>

<%- include('../partials/footer') %>
