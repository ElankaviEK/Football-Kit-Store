<%- include('../partials/header') %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <div class="admin-card">
        <h2 class="page-title mb-4"><%= product ? 'Edit Product' : 'Add New Product' %></h2>

        <% if (errors.length > 0) { %>
          <div class="alert alert-danger">
            <% errors.forEach(e => { %><div><i class="bi bi-exclamation-circle"></i> <%= e.msg %></div><% }) %>
          </div>
        <% } %>

        <form action="/admin/products<%= product ? '/' + product.id + '/edit' : '' %>" method="POST" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="mb-3">
            <label class="form-label">Product Name <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" value="<%= old.name || '' %>" required maxlength="100">
          </div>

          <div class="mb-3">
            <label class="form-label">Description <span class="text-danger">*</span></label>
            <textarea name="description" class="form-control" rows="3" maxlength="500" required><%= old.description || '' %></textarea>
          </div>

          <div class="row g-3 mb-3">
            <div class="col">
              <label class="form-label">Price (€) <span class="text-danger">*</span></label>
              <input type="number" name="price" class="form-control" step="0.01" min="0.01" value="<%= old.price || '' %>" required>
            </div>
            <div class="col">
              <label class="form-label">Stock <span class="text-danger">*</span></label>
              <input type="number" name="stock" class="form-control" min="0" value="<%= old.stock !== undefined ? old.stock : '' %>" required>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Category <span class="text-danger">*</span></label>
            <select name="category" class="form-select" required>
              <option value="">Select category</option>
              <% ['Jersey','National','Kit','Shorts','Goalkeeper','Accessories'].forEach(cat => { %>
                <option value="<%= cat %>" <%= (old.category === cat) ? 'selected' : '' %>><%= cat %></option>
              <% }) %>
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label">Image Filename</label>
            <input type="text" name="image" class="form-control" value="<%= old.image || '' %>" placeholder="e.g. jersey.jpg">
            <div class="form-text">Leave blank to use default image.</div>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-accent">
              <i class="bi bi-check-circle"></i> <%= product ? 'Save Changes' : 'Add Product' %>
            </button>
            <a href="/admin/products" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
