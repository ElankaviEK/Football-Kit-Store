<%- include('../partials/header') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">Manage Products</h1>
    <a href="/admin/products/new" class="btn btn-accent"><i class="bi bi-plus-circle"></i> Add Product</a>
  </div>

  <div class="admin-card">
    <div class="table-responsive">
      <table class="table table-hover admin-table align-middle">
        <thead>
          <tr>
            <th>#</th><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(p => { %>
          <tr>
            <td class="text-muted small"><%= p.id %></td>
            <td class="fw-medium"><%= p.name %></td>
            <td><span class="badge bg-secondary"><%= p.category %></span></td>
            <td class="text-accent fw-bold">€<%= p.price.toFixed(2) %></td>
            <td>
              <% if (p.stock === 0) { %>
                <span class="badge bg-danger">Out of Stock</span>
              <% } else if (p.stock < 5) { %>
                <span class="badge bg-warning text-dark"><%= p.stock %> left</span>
              <% } else { %>
                <span class="text-success"><%= p.stock %></span>
              <% } %>
            </td>
            <td>
              <a href="/admin/products/<%= p.id %>/edit" class="btn btn-sm btn-outline-secondary me-1">
                <i class="bi bi-pencil"></i>
              </a>
              <form action="/admin/products/<%= p.id %>/delete" method="POST" class="d-inline"
                    onsubmit="return confirm('Delete <%= p.name %>? This cannot be undone.')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-3">
    <a href="/admin" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
  </div>
</div>

<%- include('../partials/footer') %>
