<%- include('../partials/header') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">Manage Users</h1>
    <a href="/admin" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Dashboard</a>
  </div>

  <div class="admin-card">
    <div class="table-responsive">
      <table class="table table-hover admin-table align-middle">
        <thead>
          <tr><th>#</th><th>Name</th><th>Email</th><th>Role</th><th>Registered</th></tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
          <tr>
            <td class="text-muted small"><%= u.id %></td>
            <td class="fw-medium"><%= u.name %></td>
            <td class="text-muted"><%= u.email %></td>
            <td>
              <% if (u.role === 'admin') { %>
                <span class="badge bg-warning text-dark"><i class="bi bi-shield-lock"></i> Admin</span>
              <% } else { %>
                <span class="badge bg-secondary">Customer</span>
              <% } %>
            </td>
            <td class="text-muted small"><%= new Date(u.created_at).toLocaleDateString('en-IE') %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
